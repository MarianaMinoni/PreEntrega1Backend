<div>   
<div>
    <form id="productForm" action="hhtp://localhost:8080/api/products" method="post">
        <div class="mb-3">
            <label for="title" class="form-label">Nombre del producto</label>
            <input type="text" class="form-control" id="title" name="title">
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Descripción</label>
            <input type="text" class="form-control" id="description" name="description">
        </div>
         <div class="mb-3">
            <label for="code" class="form-label">Código</label>
            <input type="text" class="form-control" id="code" name="code">
        </div>
         <div class="mb-3">
            <label for="price" class="form-label">Precio</label>
            <input type="text" class="form-control" id="price" name="price">
        </div>
        <div class="mb-3">
            <label for="text" class="form-label">Categoría</label>
            <input type="text" class="form-control" id="category" name="category">
        </div>

        <button type="submit" id="addButton" class="btn btn-primary">Agregar</button>
    </form>
</div>
</div>

